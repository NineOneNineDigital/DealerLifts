# Clerk auth (will be removed in Phase 4)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Hygraph CMS (kept)
HYGRAPH_CONTENT_API_URL=
HYGRAPH_CONTENT_API_READ_TOKEN=

# Site URL (kept)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Shopify Storefront API ---
# Your Shopify domain, e.g. dealerlifts.myshopify.com (NOT the custom domain)
SHOPIFY_STORE_DOMAIN=
# Public Storefront API access token from Shopify Admin > Apps > Headless / Storefront API
SHOPIFY_STOREFRONT_API_TOKEN=
# API version, e.g. 2025-01 (use the most recent stable)
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# --- Shopify Customer Account API ---
# From Shopify Admin → Settings → Customer accounts → "New customer accounts" → Headless
# Client ID (public — safe to expose in browser)
NEXT_PUBLIC_SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
# Customer Account API URL, e.g. https://shopify.com/authentication/<store-id>
SHOPIFY_CUSTOMER_ACCOUNT_API_URL=
# Full URL this app is deployed at — used as OAuth redirect origin
NEXT_PUBLIC_SHOPIFY_APP_URL=http://localhost:3000
