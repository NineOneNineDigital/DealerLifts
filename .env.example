# Hygraph CMS (kept)
HYGRAPH_CONTENT_API_URL=
HYGRAPH_CONTENT_API_READ_TOKEN=

# Site URL (kept)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Shopify Storefront API ---
# Your Shopify domain, e.g. dealerlifts.myshopify.com (NOT the custom domain)
SHOPIFY_STORE_DOMAIN=
# Public Storefront API access token from Shopify Admin > Apps > Headless / Storefront API
SHOPIFY_STOREFRONT_API_TOKEN=
# API version, e.g. 2025-01 (use the most recent stable)
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# --- Shopify Customer Account API ---
# From Shopify Admin → Settings → Customer accounts → "New customer accounts" → Headless config.
# OAuth client ID for the headless configuration.
SHOPIFY_CUSTOMER_ACCOUNT_API_CLIENT_ID=
# Customer Account API base URL, e.g. https://shopify.com/authentication/<store-id>
# (the /graphql suffix is appended by the code).
SHOPIFY_CUSTOMER_ACCOUNT_API_URL=
# OAuth authorize/token base URL for the headless config (the "Account URL" origin).
SHOPIFY_CUSTOMER_ACCOUNT_AUTH_URL=
# NOTE: the OAuth redirect origin is derived from NEXT_PUBLIC_SITE_URL above —
# set that to the deployed URL (e.g. https://dealerlifts.com) in production.

# --- Environment notes ---
# The following are validated at startup (see lib/env.ts + instrumentation.ts).
# A deploy missing any of them fails fast at boot instead of rendering broken pages:
#   NEXT_PUBLIC_SITE_URL, SHOPIFY_STORE_DOMAIN, SHOPIFY_STOREFRONT_API_TOKEN,
#   SHOPIFY_CUSTOMER_ACCOUNT_API_CLIENT_ID, SHOPIFY_CUSTOMER_ACCOUNT_API_URL,
#   SHOPIFY_CUSTOMER_ACCOUNT_AUTH_URL, HYGRAPH_CONTENT_API_URL
# HYGRAPH_CONTENT_API_READ_TOKEN is optional (anonymous Hygraph reads work without it),
# so it is NOT startup-validated.
#
# Per-environment values (Vercel):
#   Production scope  → live-store SHOPIFY_* + NEXT_PUBLIC_SITE_URL=https://dealerlifts.com
#   Preview scope     → dev-store  SHOPIFY_* + NEXT_PUBLIC_SITE_URL=https://staging.dealerlifts.com
#   Shared (all)      → HYGRAPH_*, NEXT_PUBLIC_TAWK_*, SHOPIFY_STOREFRONT_API_VERSION
